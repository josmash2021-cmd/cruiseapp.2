rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /verifications/{docId} {
      allow read, write: if request.auth != null;
    }
    match /clients/{docId} {
      allow read, write: if request.auth != null;
    }
    match /drivers/{docId} {
      allow read, write: if request.auth != null;
    }
    match /trips/{docId} {
      allow read, write: if request.auth != null;
    }
    match /users/{docId} {
      allow read, write: if request.auth != null;
    }
    match /admins/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
